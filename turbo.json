{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.example", "tsconfig.json", ".nvmrc"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "!dist/**/*.test.*"],
      "inputs": ["src/**", "tsconfig.json", "tsup.config.*", "package.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": ["**/*.tsbuildinfo"],
      "inputs": ["src/**", "tests/**", "tsconfig.json", "package.json"]
    },
    "lint": {
      "outputs": [],
      "inputs": [
        "src/**",
        "tests/**",
        "*.{js,mjs,cjs,ts,mts,cts}",
        "package.json",
        "../../eslint.config.mjs"
      ]
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "vitest.config.*", "package.json"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false,
      "outputs": []
    }
  }
}
